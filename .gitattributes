# Normalize line endings so the working tree stops churning LF<->CRLF on commit.
# Text files are stored LF in the repo and checked out LF; Windows-only shell
# scripts stay CRLF so they run correctly.
* text=auto eol=lf

# Windows shell / PowerShell scripts must keep CRLF.
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Binary assets — never normalize.
*.png   binary
*.ico   binary
*.cat   binary
