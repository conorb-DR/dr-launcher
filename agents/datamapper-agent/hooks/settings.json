{
  "hooks": {
    "PostToolUse": [
      {
        "_owner": "dr-agent",
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -File \"./[[CLAUDE_DIR]]validate-mapper-spec.ps1\"",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Validating mapper spec..."
          }
        ]
      }
    ]
  }
}
