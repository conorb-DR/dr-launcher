{
  "name": "dr-launcher",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "build": "powershell -ExecutionPolicy Bypass -File packaging/build.ps1",
    "test": "node --test tests/**/*.test.js",
    "lint:paths": "node scripts/lint-agent-paths.js",
    "gen:server-maps": "node scripts/gen-server-maps.js",
    "check:server-maps": "node scripts/gen-server-maps.js --check",
    "check:frontend": "node scripts/check-frontend-syntax.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.1",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0"
  }
}
